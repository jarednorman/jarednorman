{
  "project_panel": {
    "hide_root": true,
    "indent_guides": {
      "show": "never"
    },
    "scrollbar": {
      "show": "never"
    },
    "bold_folder_labels": false,
    "starts_open": false,
    "indent_size": 20.0,
    "git_status": true,
    "folder_icons": true,
    "file_icons": true
  },
  "outline_panel": {
    "button": false
  },
  "git_panel": {
    "button": false
  },
  "notification_panel": {
    "button": false
  },
  "collaboration_panel": {
    "button": false
  },
  "terminal": {
    "font_size": 12.0,
    "dock": "right",
    "scrollbar": {
      "show": "never"
    }
  },
  "diagnostics": {
    "inline": {
      "enabled": false,
    },
  },
  "buffer_font_weight": 400.0,
  "buffer_line_height": "comfortable",
  "show_edit_predictions": true,
  "wrap_guides": [80, 100],
  "edit_predictions": {
    "provider": "copilot",
    "disabled_globs": [".env"],
  },
  "agent": {
    "button": true,
    "enabled": false,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "ui_font_size": 12.0,
  "ui_font_family": ".SystemUIFont",
  "buffer_font_family": "Fira Code",
  "buffer_font_size": 12.0,
  "theme": {
    "mode": "light",
    "light": "Rosé Pine Dawn",
    "dark": "Rosé Pine",
  },
  "gutter": {
    "folds": false,
  },
  "indent_guides": {
    "enabled": false,
  },
  "inline_code_actions": false,
  "git": {
    "git_gutter": "hide",
    "inline_blame": {
      "enabled": false,
    },
  },
  "scrollbar": {
    "git_diff": false,
  },
  "soft_wrap": "editor_width",
  "use_autoclose": false,
  "languages": {
    "Markdown": {
      "soft_wrap": "bounded",
      "tab_size": 4
    },
    "Astro": {
      "tab_size": 2
    },
    "Ruby": {
      "tab_size": 2,
      "language_servers": ["ruby-lsp", "!solargraph", "!rubocop"],
      "formatter": "language_server",
      "format_on_save": "on",
    },
    "CSS": {
      "tab_size": 2,
    },
    "ERB": {
      "tab_size": 2,
    },
    "HTML": {
      "tab_size": 2,
    },
    "C": {
      "language_servers": ["!clangd"],
    },
    "C++": {
      "language_servers": ["!clangd"],
    },
  },
  "lsp": {
    "ruby-lsp": {
      "initialization_options": {
        "enabledFeatures": {
          "diagnostics": false,
          "formatting": true,
          "onTypeFormatting": false,
        },
        "formatter": "standard",
      },
    },
  },
}
